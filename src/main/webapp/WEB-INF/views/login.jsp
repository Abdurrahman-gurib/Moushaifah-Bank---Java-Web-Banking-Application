<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %><!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Moushaifah Bank</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/style.css"></head><body><nav class="navbar"><a class="brand" href="${pageContext.request.contextPath}/">✦ Moushaifah Bank</a><div><a href="${pageContext.request.contextPath}/login">Login</a><a href="${pageContext.request.contextPath}/register">Register</a></div></nav><main class="auth"><form class="card" method="post"><h1>Welcome back</h1><p>Login to your Moushaifah Bank portal.</p><c:if test="${not empty error}"><div class="alert error">${error}</div></c:if><c:if test="${not empty success}"><div class="alert success">${success}</div></c:if><label>Email</label><input name="email" type="email" value="demo@moushaifahbank.com" required><label>Password</label><input name="password" type="password" value="Password123" required><button class="btn full">Login Securely</button><a href="${pageContext.request.contextPath}/forgot-password">Forgot password?</a></form></main><footer>© 2026 Moushaifah Bank - Secure digital banking demo built with Java Servlets, Hibernate and SQLite.</footer><script src="${pageContext.request.contextPath}/assets/js/app.js"></script></body></html>
