<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %><!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Moushaifah Bank</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/style.css"></head><body><nav class="navbar"><a class="brand" href="${pageContext.request.contextPath}/">✦ Moushaifah Bank</a><div><a href="${pageContext.request.contextPath}/login">Login</a><a href="${pageContext.request.contextPath}/register">Register</a></div></nav><main class="dashboard"><div class="dash-head"><div><h1>Good day, ${user.fullName}</h1><p>Here is your Moushaifah Bank financial overview.</p></div><a class="btn ghost" href="logout">Logout</a></div><section class="grid"><c:forEach items="${accounts}" var="a"><div class="card stat"><span>${a.type}</span><h2>MUR ${a.balance}</h2><p>Account No: ${a.accountNumber}</p><p>Status: ${a.status}</p></div></c:forEach><div class="card stat"><span>Security Score</span><h2>98%</h2><p>BCrypt password hashing + session protection.</p></div></section><section class="card"><h2>Recent Transactions</h2><table><tr><th>Date</th><th>Description</th><th>Type</th><th>Amount</th></tr><c:forEach items="${transactions}" var="t"><tr><td>${t.txDate}</td><td>${t.description}</td><td><span class="pill">${t.type}</span></td><td>MUR ${t.amount}</td></tr></c:forEach></table></section></main><footer>© 2026 Moushaifah Bank - Secure digital banking demo built with Java Servlets, Hibernate and SQLite.</footer><script src="${pageContext.request.contextPath}/assets/js/app.js"></script></body></html>
