<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %><!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Moushaifah Bank</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/style.css"></head><body><nav class="navbar"><a class="brand" href="${pageContext.request.contextPath}/">✦ Moushaifah Bank</a><div><a href="${pageContext.request.contextPath}/login">Login</a><a href="${pageContext.request.contextPath}/register">Register</a></div></nav><main class="auth"><form class="card" method="post" action="${pageContext.request.contextPath}/forgot-password"><h1>Reset password</h1><p>Demo reset using a security answer. Try answer <b>blue</b> for demo users.</p><c:if test="${not empty error}"><div class="alert error">${error}</div></c:if><c:if test="${not empty success}"><div class="alert success">${success}</div></c:if><label>Email</label><input name="email" type="email" required><label>Security answer</label><input name="answer" required><label>New password</label><input name="password" type="password" minlength="8" required><button class="btn full">Reset Password</button></form></main><footer>© 2026 Moushaifah Bank - Secure digital banking demo built with Java Servlets, Hibernate and SQLite.</footer><script src="${pageContext.request.contextPath}/assets/js/app.js"></script></body></html>
